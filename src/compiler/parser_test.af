str: @str

// Double curried continuation
printf: (value: str, ok:()) {
    @write(value, ok)
}
Pair: (left: int, right: int)

foo: (ok:(str)){
    greeting: "charlie"
    ok(greeting)
}
baz: (ok:(str, str)){
    foo(ok("bob"))
}
bar: (name0: str, name1: str, name2: str){
    printf(name0)
}
baz(bar("alice"))
