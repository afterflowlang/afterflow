math: /std/math

main: () {
	(absolute: @f64) = math.abs(2.0)
	(arc_cosine: @f64) = math.acos(1.0)
	(inverse_hyperbolic_cosine: @f64) = math.acosh(1.0)
	(arc_sine: @f64) = math.asin(0.0)
	(inverse_hyperbolic_sine: @f64) = math.asinh(0.0)
	(arc_tangent: @f64) = math.atan(1.0)
	(arc_tangent_xy: @f64) = math.atan2(1.0, 1.0)
	(inverse_hyperbolic_tangent: @f64) = math.atanh(0.0)
	(cube_root: @f64) = math.cbrt(8.0)
	(ceiling: @f64) = math.ceil(1.2)
	(copied_sign: @f64) = math.copy_sign(1.0, 0.0)
	(cosine: @f64) = math.cos(0.0)
	(hyperbolic_cosine: @f64) = math.cosh(0.0)
	(positive_difference: @f64) = math.dim(3.0, 2.0)
	(exponential: @f64) = math.exp(1.0)
	(binary_exponential: @f64) = math.exp2(3.0)
	(accurate_exponential_difference: @f64) = math.exp_m1(1.0)
	(floor: @f64) = math.floor(1.8)
	(hypotenuse: @f64) = math.hypot(3.0, 4.0)
	(scaled: @f64) = math.ldexp(0.5, 4)
	(natural_logarithm: @f64) = math.ln(1.0)
	(accurate_natural_logarithm: @f64) = math.ln_1p(1.0)
	(logarithm: @f64) = math.log(8.0, 2.0)
	(decimal_logarithm: @f64) = math.log10(100.0)
	(binary_logarithm: @f64) = math.log2(8.0)
	(maximum: @f64) = math.max_f64(1.0, 2.0)
	(minimum: @f64) = math.min_f64(1.0, 2.0)
	(modulus: @f64) = math.mod(5.0, 2.0)
	(next: @f64) = math.next_after(1.0, 2.0)
	(power: @f64) = math.pow(2.0, 8.0)
	(remainder: @f64) = math.remainder(5.0, 2.0)
	(rounded: @f64) = math.round(1.5)
	(sine: @f64) = math.sin(0.0)
	(hyperbolic_sine: @f64) = math.sinh(0.0)
	(square_root: @f64) = math.sqrt(9.0)
	(tangent: @f64) = math.tan(0.0)
	(hyperbolic_tangent: @f64) = math.tanh(0.0)
	(degrees: @f64) = math.to_degrees(1.0)
	(radians: @f64) = math.to_radians(180.0)
	(truncated: @f64) = math.trunc(1.8)
	@exit(0)
}
