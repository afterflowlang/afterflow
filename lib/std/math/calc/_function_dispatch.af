math: /std/math

apply_unary_function: (source_nth: nth, start: @uint, end: @uint, value: calculation, invalid: (), ok: (calculation)) {
	range_equals_name(
		source_nth,
		start,
		end,
		"abs",
		ok(apply_unary_operation(math.abs, value)),
		() {
			range_equals_name(
				source_nth,
				start,
				end,
				"acos",
				ok(apply_unary_operation(math.acos, value)),
				() {
					range_equals_name(
