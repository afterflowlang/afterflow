apply_binary_function: (source_nth: nth, start: @uint, end: @uint, a: calculation, b: calculation, invalid: (), ok: (calculation)) {
	range_equals_name(
		source_nth,
		start,
		end,
		"atan2",
		ok(apply_binary_operation(math.atan2, a, b)),
		() {
			range_equals_name(
				source_nth,
				start,
				end,
				"hypot",
				ok(apply_binary_operation(math.hypot, a, b)),
				() {
					range_equals_name(
						source_nth,
						start,
						end,
						"log",
						ok(apply_binary_operation(math.log, a, b)),
						() {
							range_equals_name(
								source_nth,
								start,
								end,
								"max",
								ok(apply_binary_operation(math.max_f64, a, b)),
								() {
									range_equals_name(
										source_nth,
										start,
										end,
										"min",
										ok(apply_binary_operation(math.min_f64, a, b)),
										() {
											range_equals_name(
												source_nth,
												start,
												end,
												"mod",
												ok(apply_binary_operation(math.mod, a, b)),
												() {
													range_equals_name(
														source_nth,
														start,
														end,
														"pow",
														ok(power(a, b)),
														() {
															range_equals_name(
																source_nth,
																start,
																end,
																"remainder",
																ok(
																	apply_binary_operation(
																		math.remainder,
																		a,
																		b
																	)
																),
																invalid
															)
														}
													)
												}
											)
										}
									)
								}
							)
						}
					)
				}
			)
		}
	)
}
