																																																),
																																																() {
																																																	range_equals_name(
																																																		source_nth,
																																																		start,
																																																		end,
																																																		"sinh",
																																																		ok(
																																																			apply_unary_operation(
																																																				math.sinh,
																																																				value
																																																			)
																																																		),
																																																		() {
																																																			range_equals_name(
																																																				source_nth,
																																																				start,
																																																				end,
																																																				"sqrt",
																																																				ok(
																																																					apply_unary_operation(
																																																						math.sqrt,
																																																						value
																																																					)
																																																				),
