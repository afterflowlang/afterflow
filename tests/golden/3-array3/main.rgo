stdout: /stdout

str: @str
int: @int

array3: (a:str, b:str, c:str, ok:(len:int, nth:(index:int, one:(str), none:()))){
    ok(3, (index:int, one:(str), none:()){
        @eq_int(index, 0, () {one(a)}, () {
            @eq_int(index, 1, () {one(b)}, () {
                @eq_int(index, 2, () {one(c)}, none)
            })
        })
    })
}
main: () {
    array3("alice", "bob", "charlie", (len:int, nth:(index:int, one:(str), none:())){
        () = stdout.printf("array has %d elements\n", len)
        nth(1, (s:str){
            stdout.printf("element at index 1 is %s\n", s, @exit(0))
        }, () {
            stdout.printf("index out of bounds\n", @exit(0))
        })
    })
}
