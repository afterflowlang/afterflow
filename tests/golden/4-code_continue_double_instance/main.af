fmt: /std/fmt
str: @str
int: @int

foo: (x:int, y:int, ok:(int)){
    @add(x, y, ok)
}
run: (ok:()){
    f: foo(1)
    a: f(2)
    b: f(3)
    k: (x:int){
        fmt.new("number: %", @exit(1), fmt.int(x) fmt.end, @write(ok: ok))
    }
    @eq_int(1, 1, () {
        a(k)
    }, () {
        b(k)
    })
}
main: () {
    run(@exit(0))
}
