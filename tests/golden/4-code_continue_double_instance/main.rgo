stdout: /stdout

str: @str
int: @int

foo: (x:int, y:int, ok:(int)){
    @add(x, y, ok)
}
run: (ok:()){
    f: foo(1)
    a: f(2)
    b: f(3)
    k: (x:int){
        stdout.printf("number: %d", x, ok)
    }
    @eq_int(1, 1, () {
        a(k)
    }, () {
        b(k)
    })
}
main: () {
    run(@exit(0))
}
