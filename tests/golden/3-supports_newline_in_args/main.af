fmt: /std/fmt
str: @str
int: @int

as_int: (x:int, ok:(int), (str)){
    ok(x)
}
int_or_str: ((int), (str))
foo: (x: int_or_str, ok:()){
    x( 
        (x: int){
            fmt.new("number: %", fmt.int(x) fmt.end, @write(ok: ok))
        },
        (x: str){
            fmt.new("x is str: %\n", fmt.str(x) fmt.end, @write(ok: ok))
        }
    )
}
main: () {
    foo(as_int(42), @exit(0))
}
