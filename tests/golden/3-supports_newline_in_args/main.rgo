stdout: /stdout

str: @str
int: @int

as_int: (x:int, ok:(int), (str)){
    ok(x)
}
int_or_str: ((int), (str))
foo: (x: int_or_str, ok:()){
    x( 
        (x: int){
            stdout.printf("number: %d", x, ok)
        },
        (x: str){
            stdout.printf("x is str: %s\n", x, ok)
        }
    )
}
main: () {
    foo(as_int(42), @exit(0))
}
