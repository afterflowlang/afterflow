stdout: /stdout

str: @str
int: @int

foo: (x:int, y:int, ok:(int)){
    @add(x, y, ok)
}
run: (ok:()){
    f: foo(1) // `f` is now `(y:int, ok:(int))`
    a: f(2) // `a` is now `(ok:(int))`
    k: (x:int){
        stdout.printf("number: %d", x, ok)
    }
    @eq_int(1, 1, () {
        a(k)
    }, () {
        a(k)
    })
}
main: () {
    run(@exit(0))
}
