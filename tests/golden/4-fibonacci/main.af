fmt: /std/fmt
str: @str
int: @int

fib_iter: (n: int, a: int, b: int, k: (int)){
    @eq_int(n, 0, () {
        k(a)
    }, () {
        @sub(n, 1, (n1: int){
            @add(a, b, (ab: int){
                fib_iter(n1, b, ab, k)
            })
        })
    })
}

fib: (n: int, k: (int)){
    fib_iter(n, 0, 1, k)
}

main: () {
    (result: int) = fib(7)
    fmt.new("fib(7) = %\n", @exit(1), fmt.int(result) fmt.end, @write(ok: @exit(0)))
}
