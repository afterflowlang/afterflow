stdout: /stdout

str: @str
int: @int

as_int: (x:int, ok:(int), (str)){
    ok(x)
}
as_str: (x:str, (int), ok:(str)){
    ok(x)
}
int_or_str: (i:(int), s:(str))
foo: (x: int_or_str, ok:()){
    x((x: int){
        stdout.printf("number: %d", x, ok)
    }, 
    (x: str){
        stdout.printf("string: %s", x, ok)
    })
}
main: () {
    foo(as_int(42), @exit(0))
}
