fmt: /std/fmt
str: @str
int: @int

as_int: (x:int, ok:(int), (str)){
    ok(x)
}
as_str: (x:str, (int), ok:(str)){
    ok(x)
}
int_or_str: (i:(int), s:(str))
foo: (x: int_or_str, ok:()){
    x((x: int){
        fmt.new("number: %", @exit(1), fmt.int(x) fmt.end, @write(ok: ok))
    }, 
    (x: str){
        fmt.new("string: %", @exit(1), fmt.str(x) fmt.end, @write(ok: ok))
    })
}
main: () {
    foo(as_int(42), @exit(0))
}
