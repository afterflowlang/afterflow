fmt: /std/fmt
str: @str
int: @int

list: ((int, list), ())
nil: (next:(int, ((int, list), ())), end:()){
    end()
}

cons: (head: int, tail:((int, list), ()), next:(int, ((int, list), ())), end:()){
    next(head, tail)
}

iterate_iterate_inner: (handler:(int, ()), iterate:((int, ()), ((int, ((int, list), ())), ()), ()), end:(), head: int, tail:((int, list), ())){
    next_iterate: iterate(handler, tail, end)
    handler(head, next_iterate)
}

iterate: (handler:(int, ()), arr:((int, list), ()), end:()){
    iterate_inner: iterate_iterate_inner(handler, iterate, end)
    arr(iterate_inner, end)
}

handler: (n: int, ok:()){
    fmt.new("%, ", @exit(1), fmt.int(n) fmt.end, @write(ok: ok))
}

end_exit: (){
    @exit(0)
}

end: (){
    fmt.new("end\n", @exit(1), fmt.end, @write(ok: end_exit))
}
mylist: cons(1, nil)
main: () {
    iterate(handler, mylist, end)
}
