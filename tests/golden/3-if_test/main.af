fmt: /std/fmt
str: @str
int: @int

true: (x: (), y: ()){
    x()
}
false: (x: (), y: ()){
    y()
}
if: (cond: ((),()), yes:(), no:()){
    cond(yes, no)
}
main: () {
    () = if(true, () {
        fmt.new("works", fmt.end, @write(ok: @exit(0)))
    })
    fmt.new("doesn't work", fmt.end, @write(ok: @exit(0)))
}
