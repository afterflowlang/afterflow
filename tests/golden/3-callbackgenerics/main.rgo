stdout: /stdout

str: @str
int: @int

foo: (p:(()), ok:()){
	p(ok)
}
print1: (n:str, ok:()){
	stdout.printf("The losing number is %s\n", n, ok)
}
print2: (n:str, ok:()){
	stdout.printf("The winning number is %s\n", n, ok)
}
p1: (ok:()){print1("41", ok)}
p2: (ok:()){print2("42", ok)}
main: () {
    foo(p1, (){
    foo(p2, @exit(0))
    })
}
