fmt: /std/fmt
str: @str
int: @int

three: (f: (int, (int)), x: int, ok: (int)){
    f(x, (y: int){
        f(y, (z: int){
            f(z, ok)
        })
    })
}
main: () {
    three((x: int, ok:(int)){
        @add(x, 10, ok)
    }, 0, (x: int){
        fmt.new("result: %", fmt.int(x) fmt.end, @write(ok: @exit(0)))
    })
}
